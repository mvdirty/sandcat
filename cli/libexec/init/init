source "$SCT_LIBDIR/logging.bash"
# shellcheck source=../../lib/require.bash
source "$SCT_LIBDIR/require.bash"
# shellcheck source=../../lib/select.bash
source "$SCT_LIBDIR/select.bash"
# shellcheck source=../../lib/constants.bash
source "$SCT_LIBDIR/constants.bash"
# shellcheck source=../../lib/path.bash
source "$SCT_LIBDIR/path.bash"
# shellcheck source=../../lib/stacks.bash
source "$SCT_LIBDIR/stacks.bash"

# Creates ~/.config/sandcat/settings.json if it doesn't already exist.
# Derives git identity from the host's git config.
create_user_settings() {
	local user_settings_dir="$SCT_HOME"
	local user_settings="$user_settings_dir/settings.json"

	if [[ -f "$user_settings" ]]; then
		return
	fi

	mkdir -p "$user_settings_dir"
	cp "$SCT_TEMPLATEDIR/settings-user.json" "$user_settings"

	# Derive git identity from host config
	local git_name git_email
	git_name=$(git config --global user.name 2>/dev/null || echo "")
	git_email=$(git config --global user.email 2>/dev/null || echo "")

	git_name="${git_name:-Your Name}" git_email="${git_email:-you@example.com}" \
		yq -i -o json '
			.env.GIT_USER_NAME = env(git_name) |
			.env.GIT_USER_EMAIL = env(git_email)
		' "$user_settings"
}

# Initializes sandcat for a project.
# Prompts for any options not provided via flags.
# Args:
#   --agent - Agent type (claude, copilot, codex)
#   --ide - IDE for devcontainer mode (vscode, jetbrains, none)
#   --name - Project name for Docker Compose
#   --path - Project directory path
#   --stacks - Comma-separated list of development stacks (node,python,java,...)
init() {
	require yq

	local name=""
	local project_path=""
	local agent=""
	local ide=""
	local stacks_csv=""
	local stacks_provided=false

	while [[ $# -gt 0 ]]
	do
		case $1 in
		--name|--path|--agent|--ide|--stacks)
			if [[ $# -lt 2 ]]; then
				echo "Option $1 requires a value" | error
				return 1
			fi
			;;&
		--name)
			name="$2"
			shift 2
			;;
		--path)
			project_path="$2"
			shift 2
			;;
		--agent)
			agent="$2"
			shift 2
			;;
		--ide)
			ide="$2"
			shift 2
			;;
		--stacks)
			stacks_csv="$2"
			stacks_provided=true
			shift 2
			;;
		*)
			echo "Unknown option: $1" | error
			return 1
			;;
		esac
	done

	if [[ -z "$project_path" ]]
	then
		project_path="."
	fi

	if [[ ! -d "$project_path" ]]
	then
		echo "Directory does not exist: $project_path" | error
		return 1
	fi
	project_path=$(cd "$project_path" && pwd)

	echo "Configuring project at: $project_path" | info

	local default_name
	default_name="$(derive_project_name "$project_path")"
	if [[ -z "$name" ]]
	then
		name=$(read_line "Project name [$default_name]:")
	fi

	local available_agents=(claude)
	if [[ -z "$agent" ]]
	then
		agent=$(select_option "Select agent:" "${available_agents[@]}")
	elif [[ ! " ${available_agents[*]} " =~ [[:space:]]${agent}[[:space:]] ]]
	then
		echo "Invalid agent: $agent (expected: ${available_agents[*]})" | error
		return 1
	fi

	if [[ -z "$name" ]]
	then
		name="$default_name"
	fi

	local settings_file="$SCT_PROJECT_DIR/settings.json"

	local available_ides=(vscode jetbrains none)
	if [[ -z "$ide" ]]
	then
		ide=$(select_option "Select IDE:" "${available_ides[@]}")
	elif [[ ! " ${available_ides[*]} " =~ [[:space:]]${ide}[[:space:]] ]]
	then
		echo "Invalid IDE: $ide (expected: ${available_ides[*]})" | error
		return 1
	fi

	# Stack selection
	local stacks_resolved=""
	if [[ "$stacks_provided" == "true" ]] && [[ -n "$stacks_csv" ]]; then
		local stacks_arr=()
		IFS=',' read -ra stacks_arr <<< "$stacks_csv"
		local errmsg
		if ! errmsg=$(validate_stacks "${stacks_arr[@]}"); then
			echo "$errmsg" | error
			return 1
		fi
		stacks_resolved=$(resolve_stacks "${stacks_arr[@]}")
	elif [[ "$stacks_provided" != "true" ]]; then
		local selected
		selected=$(select_multiple "Select development stacks (comma-separated numbers, empty for none):" "${STACK_NAMES[@]}")
		if [[ -n "$selected" ]]; then
			local stacks_arr=()
			read -ra stacks_arr <<< "$selected"
			stacks_resolved=$(resolve_stacks "${stacks_arr[@]}")
		fi
	fi

	local services=("$agent")
	if [[ "$ide" != "none" ]]
	then
		services+=("$ide")
	fi

	create_user_settings
	settings "$project_path/$settings_file" "${services[@]}"
	devcontainer \
		--settings-file "$settings_file" \
		--project-path "$project_path" \
		--agent "$agent" \
		--ide "$ide" \
		--name "$name" \
		--stacks "$stacks_resolved"

	# Summary
	echo "" >&2
	echo "Initialization complete." | info
	if [[ -n "$stacks_resolved" ]]; then
		echo "  Stacks:           $stacks_resolved (edit .devcontainer/Dockerfile.app to change versions)" | info
	fi
	echo "  Project settings: $SCT_PROJECT_DIR/settings.json (network rules)" | info
	echo "  User settings:    ~/.config/sandcat/settings.json (git identity, API keys)" | info
	echo "  Devcontainer:     .devcontainer/" | info
	echo "" >&2
	echo "Next steps:" | info
	echo "  Edit ~/.config/sandcat/settings.json to add your API keys:" | info
	echo "    ANTHROPIC_API_KEY  your Anthropic API key (for Claude Code)" | info
	echo "    GITHUB_TOKEN       a GitHub personal access token (for git push, gh cli)" | info
	echo "  Then run: sandcat run, or reopen the project using the dev container" | info
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]
then
	init "$@"
fi
