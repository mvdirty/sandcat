#!/usr/bin/env bash
set -euo pipefail

# shellcheck source=../../lib/logging.bash
source "$SCT_LIBDIR/logging.bash"
# shellcheck source=../../lib/require.bash
source "$SCT_LIBDIR/require.bash"
# shellcheck source=../../lib/path.bash
source "$SCT_LIBDIR/path.bash"

# Opens the mitmproxy interface for traffic inspection.
# In TUI mode: attaches to the running mitmproxy console.
# In web mode: prints the URL of the mitmweb UI.
proxy() {
	require docker

	local compose_file
	compose_file="$(find_compose_file)"

	# Detect mode from compose config: TUI mode has stdin_open set.
	local is_tui
	is_tui=$(docker compose -f "$compose_file" config --format json |
		yq '.services.mitmproxy.stdin_open // false')

	if [[ "$is_tui" == "true" ]]; then
		local container_id
		container_id=$(docker compose -f "$compose_file" ps -q mitmproxy)
		if [[ -z "$container_id" ]]; then
			echo "Proxy is not running. Start it first with: sandcat run or sandcat compose up -d" | error
			return 1
		fi
		echo "Attaching to mitmproxy console. Press 'q' to detach." | info
		docker attach "$container_id"
	else
		local url
		url=$(docker compose -f "$compose_file" port mitmproxy 8081 2>/dev/null) || true
		if [[ -z "$url" ]]; then
			echo "Proxy is not running. Start it first with: sandcat run or sandcat compose up -d" | error
			return 1
		fi
		echo "mitmweb UI: http://$url (password: mitmproxy)" | info
	fi
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]
then
	proxy "$@"
fi
